{
  "manifest_version": 3,
  "name": "Pro Screen Recorder",
  "version": "1.1.0",
  "description": "Screen recorder — screen, window or tab capture, mic + tab audio mix, phone-as-mic, camera bubble, pause/resume & shortcuts.",
  "permissions": [
    "desktopCapture",
    "storage",
    "downloads",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://0.peerjs.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "start-stop": {
      "suggested_key": { "default": "Alt+Shift+R", "mac": "Alt+Shift+R" },
      "description": "Start / Stop recording"
    },
    "pause-resume": {
      "suggested_key": { "default": "Alt+Shift+P", "mac": "Alt+Shift+P" },
      "description": "Pause / Resume recording"
    },
    "toggle-mic": {
      "suggested_key": { "default": "Alt+Shift+M", "mac": "Alt+Shift+M" },
      "description": "Mute / Unmute microphone"
    }
  }
}
